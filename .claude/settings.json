{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git push origin:*)",
      "Bash(git push -u origin:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow run deploy-prod.yml:*)",
      "Bash(gh workflow run seed-prod.yml:*)",
      "Bash(gh workflow run seed-culture.yml:*)",
      "Bash(gh workflow run seed-program.yml:*)",
      "Bash(gh workflow run seed-announcement.yml:*)",
      "Bash(gh workflow run seed-tatar.yml:*)",
      "Bash(corepack pnpm -C web typecheck:*)",
      "Bash(corepack pnpm -C web lint:*)",
      "Bash(corepack pnpm -C web build:*)",
      "Bash(corepack pnpm -C web install:*)",
      "Bash(corepack pnpm -C web generate:types:*)",
      "Bash(corepack pnpm -C web generate:importmap:*)",
      "Bash(corepack pnpm -C web migrate:status:*)"
    ],
    "ask": [
      "Bash(gh workflow run apply-migration.yml:*)",
      "Bash(gh workflow run moderate-vk.yml:*)",
      "Bash(gh workflow run apply-brand.yml:*)",
      "Bash(gh workflow run apply-vk-secrets.yml:*)",
      "Bash(gh workflow run apply-smtp-secrets.yml:*)",
      "Bash(gh workflow run apply-push-secrets.yml:*)",
      "Bash(gh workflow run apply-s3-keys.yml:*)",
      "Bash(gh workflow run apply-domain-env.yml:*)",
      "Bash(gh workflow run recover-fotostena-media.yml:*)",
      "Bash(gh workflow run setup-subdomain.yml:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:*)",
      "Bash(git push:* main)",
      "Bash(git push:* master)"
    ]
  }
}
