# ─────────────────────────────────────────────────────────────────────────────
# Сабантуй Малмыж — пример переменных окружения.
#
# ⚠️ Это ШАБЛОН. Реальные значения НЕ коммитим (pool #008 «секреты вне репо»).
#   • Локально:  скопировать в web/.env и подставить значения (web/.env в .gitignore).
#   • На проде:  секреты живут в /etc/sabantuy/sabantuy.env (root:0640) и
#                подключаются systemd-юнитом через EnvironmentFile=, НЕ в дереве репо.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL. Локально (Windows + системный Postgres 16): postgres/postgres.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sabantuy

# Payload auth secret (шифрует JWT). На проде — длинная случайная строка.
PAYLOAD_SECRET=generate_a_long_random_secret_here

# Публичный URL сервера (без хвостового слэша).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Email организатора — куда уходит уведомление о новой заявке (M2).
ORGANIZER_EMAIL=organizer@example.com

# SMTP-relay для исходящих писем (уведомления о заявках).
# Провайдеро-независимо: подойдёт любой внешний relay — Resend / Brevo / SendGrid /
# Mailgun и т.п. (у каждого в кабинете есть SMTP-доступы host/port/login/password).
# Пока SMTP_HOST пуст — адаптер в payload.config НЕ подключается и письма пишутся в
# консоль (WARN «No email adapter»); сборка/типы при этом зелёные. Чтобы письма
# реально уходили, заполнить все SMTP_* (на проде — в /etc/sabantuy/sabantuy.env).
#   port 465 → secure=true (implicit TLS), 587/2525 → secure=false (STARTTLS).
#   SMTP_SECURE переопределяет авто-выбор только при нестандартном relay.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=your_relay_api_key_or_password
# SMTP_FROM_ADDRESS=no-reply@sabantuy-malmyzh.ru
# SMTP_FROM_NAME=Сабантуй Малмыж
# SMTP_SECURE=false

# Прод (IDN сабантуймалмыж.рф → punycode xn--…, точное значение уточнить при настройке DNS/nginx):
# NEXT_PUBLIC_SERVER_URL=https://xn--<punycode>.xn--p1ai

# ─── Счётчики посещаемости (NEXT_PUBLIC_* — бейкаются в бандл при сборке) ──────
# Пусто → счётчики НЕ подключаются (в dev статистику не пачкаем). На проде
# задаются как Variables репозитория (GitHub → Settings → Variables) — их
# подхватывает deploy-prod.yml при сборке. Владелец заводит счётчики сам.
#   • Яндекс.Метрика: завести счётчик на metrika.yandex.ru → взять номер (цифры).
#   • LiveInternet: зарегистрировать сайт на liveinternet.ru → выставить флаг = 1.
# NEXT_PUBLIC_YANDEX_METRICA_ID=00000000
# NEXT_PUBLIC_LIVEINTERNET=1
