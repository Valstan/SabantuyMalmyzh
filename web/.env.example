# ─────────────────────────────────────────────────────────────────────────────
# Сабантуй Малмыж — пример переменных окружения.
#
# ⚠️ Это ШАБЛОН. Реальные значения НЕ коммитим (pool #008 «секреты вне репо»).
#   • Локально:  скопировать в web/.env и подставить значения (web/.env в .gitignore).
#   • На проде:  секреты живут в /etc/sabantuy/sabantuy.env (root:0640) и
#                подключаются systemd-юнитом через EnvironmentFile=, НЕ в дереве репо.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL. Локально (Windows + системный Postgres 16): postgres/postgres.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sabantuy

# Payload auth secret (шифрует JWT). На проде — длинная случайная строка.
PAYLOAD_SECRET=generate_a_long_random_secret_here

# Публичный URL сервера (без хвостового слэша).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Email организатора — куда уходит уведомление о новой заявке (M2) и заявки I6.
ORGANIZER_EMAIL=valstan@valstan.ru

# SMTP-relay для исходящих писем (уведомления о заявках + подтверждение подписки I6).
# Пока SMTP_HOST пуст — адаптер в payload.config НЕ подключается и письма пишутся в
# лог сервиса (WARN «No email adapter»); сборка/типы при этом зелёные. Чтобы письма
# реально уходили, заполнить все SMTP_* (на проде — в /etc/sabantuy/sabantuy.env).
#   port 465 → secure=true (implicit TLS), 587/2525 → secure=false (STARTTLS).
#   SMTP_SECURE переопределяет авто-выбор только при нестандартном relay.
#
# Прод: ящик valstan@valstan.ru на Яндексе (MX mx.yandex.ru). Доставка пароля —
# через GitHub Secret SMTP_PASS + воркфлоу apply-smtp-secrets.yml (секрет не в
# репо/чат, #008). Полный runbook — docs/ops/smtp-setup.md.
#   SMTP_PASS = пароль приложения Яндекса (id.yandex.ru → Пароли приложений → Почта),
#   НЕ пароль аккаунта. SMTP_FROM_ADDRESS должен совпадать с SMTP_USER (relay-policy).
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=valstan@valstan.ru
# SMTP_PASS=yandex_app_password
# SMTP_FROM_ADDRESS=valstan@valstan.ru
# SMTP_FROM_NAME="Сабантуй Малмыж"

# Прод (IDN сабантуймалмыж.рф → punycode xn--…, точное значение уточнить при настройке DNS/nginx):
# NEXT_PUBLIC_SERVER_URL=https://xn--<punycode>.xn--p1ai

# ─── Счётчики посещаемости (NEXT_PUBLIC_* — бейкаются в бандл при сборке) ──────
# Пусто → счётчики НЕ подключаются (в dev статистику не пачкаем). На проде
# задаются как Variables репозитория (GitHub → Settings → Variables) — их
# подхватывает deploy-prod.yml при сборке. Владелец заводит счётчики сам.
#   • Яндекс.Метрика: завести счётчик на metrika.yandex.ru → взять номер (цифры).
#   • LiveInternet: зарегистрировать сайт на liveinternet.ru → выставить флаг = 1.
# NEXT_PUBLIC_YANDEX_METRICA_ID=00000000
# NEXT_PUBLIC_LIVEINTERNET=1

# ─── «Народная лента» (UGC фото/видео) → Yandex Object Storage (S3) ───────────
# Медиа НЕ хранится на нашем боксе: браузер грузит файл напрямую в бакет по
# presigned-ссылке, просмотр — публичный URL объекта (бакет public-read). Пока
# ключи не заданы — endpoint /api/ugc/sign-upload отдаёт 503 (degraded), сборка
# зелёная. Настройка бакета/ключей — docs/ops/yandex-object-storage-setup.md.
# Секреты — на проде в /etc/sabantuy/sabantuy.env (#008), НЕ в репо.
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_REGION=ru-central1
# S3_BUCKET=sabantuy-ugc
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://sabantuy-ugc.storage.yandexcloud.net
# Лимиты загрузки (опц., есть дефолты 12 / 100 МБ / 60 сек):
# UGC_MAX_PHOTO_MB=12
# UGC_MAX_VIDEO_MB=100
# UGC_MAX_VIDEO_SEC=60

# ─── Вход через VK ID («Войти через ВКонтакте» для посетителей ленты) ──────────
# OAuth 2.1 + PKCE. Посетитель входит через VK → его фото/комменты/лайки в ленте
# закрепляются за аккаунтом (управление «своим» с любого устройства) + имя/аватар.
# Стафф-вход (/admin, email+пароль) этим НЕ затрагивается. ПДн минимизируем: храним
# только vkId+имя+аватар (без email/phone). Пока VK_CLIENT_ID пуст — кнопка входа не
# показывается, роуты /api/auth/vk/* → 503 (degraded), сборка зелёная.
#   App ID (не секрет) задаётся как VK_CLIENT_ID. Защищённый ключ для PKCE-обмена НЕ
#   требуется (PKCE его заменяет), но храним опционально (VK_CLIENT_SECRET) на будущее.
#   Регистрация приложения VK — docs/ops/vk-id-setup.md. Секрет — на проде в
#   /etc/sabantuy/sabantuy.env (#008) через воркфлоу apply-vk-secrets.yml, НЕ в репо.
#   redirect_uri должен СИМВОЛ-В-СИМВОЛ совпасть с зарегистрированным в кабинете VK.
# VK_CLIENT_ID=54656174
# VK_CLIENT_SECRET=
# VK_REDIRECT_URI=https://xn--80aaac1aqpgcf4bqn1j.xn--p1ai/api/auth/vk/callback
# VK_SCOPE=
